<Window x:Class="LockScreenApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project X"
        WindowStyle="None"
        WindowState="Normal"
        WindowStartupLocation="CenterScreen"
        Width="1300"
        Height="860"
        ResizeMode="NoResize"
        Topmost="True"
        Background="#111827"
        Foreground="#F9FAFB"
        Closing="Window_Closing"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="1"
            Width="1000"
            MaxWidth="1000"
            MinWidth="780"
            Padding="32"
            Background="#FFFFFF"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            CornerRadius="16">
      <StackPanel>
        <StackPanel x:Name="RegistrationPanel" Visibility="Visible">
          <StackPanel Margin="0,0,0,24">
            <TextBlock Text="PROJECT X"
                       FontSize="36"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Foreground="#111827"
                       Margin="0,0,0,8" />
            <TextBlock Text="Please provide your details to register this device."
                       FontSize="16"
                       Foreground="#6B7280"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,0" />
          </StackPanel>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="24" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical">
              <TextBlock Text="Customer name"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="#6B7280" />
              <TextBox x:Name="CustomerNameInput"
                       Height="42"
                       FontSize="15"
                       Padding="10"
                       Background="#F8FAFC"
                       Foreground="#111827"
                       BorderBrush="#D1D5DB"
                       BorderThickness="1"
                       Margin="0,8,0,0" />

              <TextBlock Text="Device name"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="#6B7280"
                         Margin="0,16,0,0" />
              <TextBox x:Name="DeviceNameInput"
                       Height="42"
                       FontSize="15"
                       Padding="10"
                       Background="#F8FAFC"
                       Foreground="#111827"
                       BorderBrush="#D1D5DB"
                       BorderThickness="1" />

              <TextBlock Text="Plan payment amount"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="#6B7280"
                         Margin="0,12,0,0" />
              <TextBox x:Name="PaymentAmountInput"
                       Height="42"
                       FontSize="15"
                       Padding="10"
                       Background="#F8FAFC"
                       Foreground="#111827"
                       BorderBrush="#D1D5DB"
                       BorderThickness="1" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Vertical">
              <TextBlock Text="Customer email"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="#6B7280" />
              <TextBox x:Name="CustomerEmailInput"
                       Height="42"
                       FontSize="15"
                       Padding="10"
                       Background="#F8FAFC"
                       Foreground="#111827"
                       BorderBrush="#D1D5DB"
                       BorderThickness="1"
                       Margin="0,8,0,0" />

              <TextBlock Text="Customer phone"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="#6B7280"
                         Margin="0,16,0,0" />
              <TextBox x:Name="PhoneNumberInput"
                       Height="42"
                       FontSize="15"
                       Padding="10"
                       Background="#F8FAFC"
                       Foreground="#111827"
                       BorderBrush="#D1D5DB"
                       BorderThickness="1" />

              <TextBlock Text="Total contract amount"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="#6B7280"
                         Margin="0,12,0,0" />
              <TextBox x:Name="TotalAmountInput"
                       Height="42"
                       FontSize="15"
                       Padding="10"
                       Background="#F8FAFC"
                       Foreground="#111827"
                       BorderBrush="#D1D5DB"
                       BorderThickness="1" />

              <TextBlock Text="Payment frequency"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="#6B7280"
                         Margin="0,12,0,0" />
              <ComboBox x:Name="PaymentFrequencyCombo"
                        Height="42"
                        FontSize="15"
                        Background="#F8FAFC"
                        Foreground="#111827"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        SelectedIndex="1">
                <ComboBoxItem Content="Weekly" />
                <ComboBoxItem Content="Monthly" />
                <ComboBoxItem Content="Yearly" />
              </ComboBox>
            </StackPanel>
          </Grid>

          <Button Content="Register this device"
                  Height="50"
                  Margin="0,24,0,0"
                  FontSize="16"
                  FontWeight="Bold"
                  Background="#111827"
                  Foreground="#FFFFFF"
                  BorderBrush="#111827"
                  BorderThickness="1"
                  Click="RegisterButton_Click" />

          <TextBlock x:Name="RegistrationMessageText"
                     Margin="0,16,0,0"
                     FontSize="14"
                     Foreground="#B91C1C"
                     TextWrapping="Wrap"
                     TextAlignment="Center" />
        </StackPanel>

        <StackPanel x:Name="PaymentPanel" Visibility="Collapsed">
          <Border Background="#000000"
                  BorderBrush="#FFFFFF1F"
                  BorderThickness="1"
                  CornerRadius="20"
                  Padding="28">
            <StackPanel>
              <TextBlock Text="Project X"
                         FontSize="42"
                         FontWeight="Bold"
                         Foreground="#FFFFFF"
                         TextAlignment="Center"
                         Margin="0,0,0,12" />
              <TextBlock Text="Your device has been locked because your payment is due."
                         FontSize="18"
                         Foreground="#D1D5DB"
                         TextAlignment="Center"
                         TextWrapping="Wrap"
                         Margin="0,0,0,24" />

              <TextBlock Text="Your device address is"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="#FFFFFF"
                         TextAlignment="Center"
                         TextWrapping="Wrap"
                         Margin="0,0,0,8" />
              <Border Background="#0F172A"
                      BorderBrush="#FFFFFF1F"
                      BorderThickness="1"
                      CornerRadius="14"
                      Padding="16"
                      Margin="0,0,0,24">
                <TextBlock x:Name="DeviceAddressText"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#FFFFFF"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
              </Border>

              <TextBlock Text="Open this link on your phone to pay:"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="#FFFFFF"
                         TextAlignment="Center"
                         Margin="0,0,0,8" />
              <TextBlock x:Name="PaymentUrlText"
                         FontSize="14"
                         Foreground="#60A5FA"
                         TextAlignment="Center"
                         TextWrapping="Wrap"
                         Margin="0,0,0,8" />
              <Button x:Name="CopyPaymentLinkButton"
                      Content="Copy payment link"
                      Height="36"
                      Width="180"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,16"
                      FontSize="14"
                      FontWeight="SemiBold"
                      Background="#FFFFFF"
                      Foreground="#111827"
                      BorderBrush="#D1D5DB"
                      BorderThickness="1"
                      Click="CopyPaymentLinkButton_Click" />

              <Border Background="#111111"
                      BorderBrush="#FFFFFF0F"
                      BorderThickness="1"
                      CornerRadius="20"
                      Height="260"
                      Margin="0,0,0,12">
                <Grid>
                  <Image x:Name="PaymentQrImage"
                         Stretch="Uniform"
                         Margin="20" />
                  <Rectangle Stroke="#FFFFFF14"
                             StrokeThickness="1"
                             RadiusX="16"
                             RadiusY="16"
                             Margin="12" />
                </Grid>
              </Border>

              <TextBlock Text="Scan the QR code below to open the payment page."
                         FontSize="12"
                         Foreground="#FFFFFFB3"
                         TextAlignment="Center"
                         TextWrapping="Wrap"
                         Margin="0,0,0,24" />

              <Button Content="I have received the code"
                      Height="48"
                      FontSize="16"
                      FontWeight="SemiBold"
                      Background="#2563EB"
                      Foreground="#FFFFFF"
                      BorderBrush="#2563EB"
                      BorderThickness="1"
                      Click="HaveCodeButton_Click" />

              <StackPanel x:Name="CodePanel" Visibility="Collapsed" Margin="0,24,0,0">
                <TextBlock Text="Enter your unlock code"
                           FontSize="16"
                           Foreground="#D1D5DB"
                           TextAlignment="Center"
                           Margin="0,0,0,16" />

                <TextBox x:Name="CodeInput"
                         Height="52"
                         MaxLength="8"
                         FontSize="24"
                         FontWeight="Bold"
                         TextAlignment="Center"
                         VerticalContentAlignment="Center"
                         Background="#F9FAFB"
                         Foreground="#111827"
                         BorderBrush="#6B7280"
                         BorderThickness="1"
                         TextChanged="CodeInput_TextChanged"
                         PreviewTextInput="CodeInput_PreviewTextInput" />

                <Button Content="Unlock"
                        Height="48"
                        Margin="0,16,0,0"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Background="#2563EB"
                        Foreground="#FFFFFF"
                        BorderBrush="#2563EB"
                        BorderThickness="1"
                        Click="UnlockButton_Click" />

                <TextBlock x:Name="MessageText"
                           Margin="0,16,0,0"
                           FontSize="14"
                           Foreground="#FCA5A5"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
              </StackPanel>

              <StackPanel Orientation="Horizontal"
                          HorizontalAlignment="Center"
                          Margin="0,28,0,0">
                <TextBlock Text="🔒"
                           FontSize="18"
                           Margin="0,0,8,0" />
                <TextBlock Text="End-to-End Encrypted"
                           FontSize="12"
                           Foreground="#FFFFFF99"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
              </StackPanel>

              <Button Content="CANCEL"
                      Height="42"
                      Margin="0,16,0,0"
                      FontSize="14"
                      FontWeight="Bold"
                      Background="Transparent"
                      Foreground="#FFFFFF99"
                      BorderBrush="#FFFFFF33"
                      BorderThickness="1"
                      Click="CancelButton_Click" />
            </StackPanel>
          </Border>
        </StackPanel>
      </StackPanel>
    </Border>

    <Border x:Name="PopupMessageBorder"
            Grid.RowSpan="3"
            Panel.ZIndex="100"
            Background="#111827"
            CornerRadius="16"
            Opacity="0"
            Visibility="Collapsed"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,24"
            Padding="16"
            MinWidth="360"
            MaxWidth="760"
            RenderTransformOrigin="0.5,0.5">
      <Border.RenderTransform>
        <TranslateTransform Y="60" />
      </Border.RenderTransform>
      <TextBlock x:Name="PopupMessageText"
                 Foreground="#F9FAFB"
                 FontSize="14"
                 TextWrapping="Wrap"
                 TextAlignment="Center" />
    </Border>
  </Grid>
</Window>
