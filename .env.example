# Supabase/Postgres connection.
# For Supabase, use the project connection string from Project Settings > Database.
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@[host]:6543/postgres
# PGSSLMODE=require

# Local Postgres fallback when DATABASE_URL is not set.
PGHOST=localhost
PGPORT=5432
PGDATABASE=financing_app
PGUSER=postgres
PGPASSWORD=postgres
PAYSTACK_SECRET=replace_with_paystack_secret
PAYSTACK_PUBLIC_KEY=replace_with_paystack_public_key
PAYMENT_CURRENCY=GHS
PAYMENT_PAGE_URL=http://localhost:3000
# Use a long random secret for token generation/verification.
# Example: openssl rand -hex 32
TOKEN_SECRET=replace_with_long_random_shared_hmac_secret
EMAIL_ENABLED=false
EMAIL_FROM="Project X <no-reply@example.com>"
SUPPORT_EMAIL=support@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=smtp_username
SMTP_PASS=smtp_password
PORT=3000
